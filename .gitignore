# ── Design & Private Docs ──────────────────────────────────────────────────
# Project-specific private filenames live in .git/info/exclude (local-only,
# not pushed) so they are not advertised in the public repository.
docs/agent-audit-remediation-guide*.md
docs/session-log-*.md

# ── Runtime Output ─────────────────────────────────────────────────────────
output/
# Keep directory structure but ignore generated files
!output/.gitkeep

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Node / npm ─────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
package-lock.json

# ── Environment & Secrets ──────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
secrets.json

# ── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editor ─────────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
*.swp
*.swo
*~

# ── Claude session artifacts ────────────────────────────────────────────────
.claude/projects/
.claude/worktrees/
