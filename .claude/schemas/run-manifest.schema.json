{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Run Manifest",
  "type": "object",
  "required": [
    "run_id",
    "created_at",
    "tickers",
    "artifact_layout",
    "artifacts"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]{8}T[0-9]{6}Z_[A-Z0-9_]+$"
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "tickers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "artifact_layout": {
      "type": "string",
      "const": "output/runs/{run_id}/{ticker}/"
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "artifact_root",
          "research_plan",
          "validated_data",
          "analysis_result",
          "quality_report"
        ],
        "properties": {
          "artifact_root": {
            "type": "string"
          },
          "research_plan": {
            "type": "string"
          },
          "tier1_raw": {
            "type": "string"
          },
          "dart_api_raw": {
            "type": "string"
          },
          "tier2_raw": {
            "type": "string"
          },
          "validated_data": {
            "type": "string"
          },
          "analysis_result": {
            "type": "string"
          },
          "quality_report": {
            "type": "string"
          },
          "snapshot_dir": {
            "type": "string"
          },
          "reports_dir": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
